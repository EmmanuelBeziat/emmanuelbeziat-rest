{
  "name": "node-rest",
  "version": "4.0.0",
  "description": "🎲 A NodeJS App that provide a very simple REST API (just GET) from markdown files.",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
		"update": "git pull && npm-check -u",
    "setup": "npm i && node setup.js",
    "build": "tsc",
    "dev": "tsc && node --watch -r dotenv/config dist/index.js",
    "prod": "tsc && node -r dotenv/config dist/index.js",
    "deploy": "tsc && pm2 start dist/index.js --name 'emmanuelb-rest' --node-args='-r dotenv/config' || pm2 reload emmanuelb-rest --update-env",
    "test": "vitest --run",
    "lint": "npx eslint src",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,cjs,mjs,ts,tsx}": [
      "npx eslint"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EmmanuelBeziat/node-rest.git"
  },
  "keywords": [
    "nodejs",
    "rest-api",
    "fastify",
    "markdown"
  ],
  "author": "EmmanuelBeziat <contact@emmanuelbeziat.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/EmmanuelBeziat/node-rest/issues"
  },
  "homepage": "https://github.com/EmmanuelBeziat/node-rest#readme",
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "fastify-favicon": "^5.0.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.3.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-block-embed": "^0.0.3",
    "markdown-it-image-lazy-loading": "^2.0.1",
    "markdown-it-prism": "^4.0.0",
    "markdown-it-smartarrows": "^1.0.1",
    "slug": "^11.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-attrs": "^4.1.3",
    "@types/node": "^26.1.0",
    "@types/slug": "^5.0.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "inquirer": "^14.0.2",
    "lint-staged": "^17.0.8",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
